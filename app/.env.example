# Copy this file to .env and fill in real values. .env is gitignored.
# main.js loads these at startup. Existing process.env values take priority,
# so CI/build-time environment variables override the .env file.

# PostHog (product analytics) — public project ingestion key
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
